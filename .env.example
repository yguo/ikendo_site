# --- BP gate (/bp) ---
BP_AUTH_USER=iam
BP_AUTH_PASSWORD=
BP_AUTH_COOKIE_SECRET=

# --- Contact form → Google Sheets + reCAPTCHA v3 ---
# First sheet row should be a header, e.g.:
# Timestamp | IP | FirstName | LastName | WorkEmail | Company | RegionKey | RegionLabel | Message | RecaptchaScore
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL (Editor).
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Sheet1!A:J
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_MIN=0.5
