# --- BP gate (/bp) ---
BP_AUTH_USER=iam
BP_AUTH_PASSWORD=
BP_AUTH_COOKIE_SECRET=

# --- Contact form → Google Sheets + reCAPTCHA v3 ---
# First sheet row should be a header, e.g.:
# Timestamp | IP | FirstName | LastName | WorkEmail | Company | RegionKey | RegionLabel | Message | RecaptchaScore
# In the same GCP project as the service account, enable Google Sheets API.
# My Drive spreadsheets: leave CONTACT_USE_DRIVE_PREFLIGHT unset (default). Uses Sheets scope only
# and skips Drive files.get (Google sometimes returns 404 there even when Sheets access is fine).
# Set CONTACT_USE_DRIVE_PREFLIGHT=1 or true only if you need Drive preflight (e.g. Shared drives).
# Enable Google Drive API in the same GCP project when using preflight.
# CONTACT_USE_DRIVE_PREFLIGHT=1
# Optional: random secret; POST /api/contact/diagnose with header x-ikendo-contact-diagnose: <secret>
# Add ?writeTestRow=1 to the diagnose URL to also try values.append (writes one test row).
# CONTACT_DIAGNOSE_SECRET=
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL (Editor).
# Use spreadsheet id only, or paste the full https://docs.google.com/spreadsheets/d/... URL.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Sheet1!A1
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_MIN=0.5
